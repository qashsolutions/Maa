## 7. DATA MODELS

### SQLite Schema

```sql
-- User profile (local only)
CREATE TABLE user_profile (
  id INTEGER PRIMARY KEY DEFAULT 1,
  phone_hash TEXT,                    -- hashed phone number
  language_code TEXT NOT NULL DEFAULT 'en',
  cycle_length_avg INTEGER DEFAULT 28,
  created_at TEXT NOT NULL,
  updated_at TEXT NOT NULL
);

-- Cycle tracking
CREATE TABLE cycles (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  start_date TEXT NOT NULL,           -- ISO date
  end_date TEXT,                      -- ISO date, null if ongoing
  flow_intensity TEXT,                -- 'light' | 'medium' | 'heavy'
  notes TEXT,
  created_at TEXT NOT NULL
);

-- Daily health log (one row per day, upserted)
CREATE TABLE daily_logs (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  log_date TEXT NOT NULL UNIQUE,      -- ISO date
  mood_level INTEGER,                 -- 1-10
  energy_level INTEGER,               -- 1-10
  sleep_hours REAL,
  pain_level INTEGER,                 -- 1-10
  symptoms TEXT,                      -- JSON array of symptom strings
  medications TEXT,                   -- JSON array
  period_status TEXT,                 -- 'menstruating' | 'fertile' | 'ovulating' | 'luteal' | null
  notes TEXT,
  voice_logged INTEGER DEFAULT 0,    -- 1 if data came from voice conversation
  created_at TEXT NOT NULL,
  updated_at TEXT NOT NULL
);

-- Voice conversation transcripts
CREATE TABLE conversations (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  session_date TEXT NOT NULL,
  user_text TEXT NOT NULL,
  ai_response TEXT NOT NULL,
  extracted_data TEXT,                -- JSON from Gemini's extracted_data
  visual_card_type TEXT,
  language_code TEXT,
  duration_seconds INTEGER,
  created_at TEXT NOT NULL
);

-- Maa Score snapshots
CREATE TABLE score_snapshots (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  snapshot_date TEXT NOT NULL UNIQUE,
  total_score INTEGER NOT NULL,
  cycle_intelligence INTEGER NOT NULL,
  mood_map INTEGER NOT NULL,
  body_awareness INTEGER NOT NULL,
  consistency INTEGER NOT NULL,
  created_at TEXT NOT NULL
);

-- Weekly goals
CREATE TABLE weekly_goals (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  week_start TEXT NOT NULL,           -- ISO date of Monday
  goal_text TEXT NOT NULL,
  goal_type TEXT NOT NULL,            -- 'sleep' | 'mood' | 'cycle' | 'symptom'
  target_count INTEGER DEFAULT 1,
  current_count INTEGER DEFAULT 0,
  completed INTEGER DEFAULT 0,
  created_at TEXT NOT NULL
);

-- Milestones
CREATE TABLE milestones (
  id TEXT PRIMARY KEY,                -- 'cycle_1' | 'cycle_3' | 'cycle_6' | 'cycle_12' | 'pregnancy'
  unlocked INTEGER DEFAULT 0,
  unlocked_at TEXT,
  progress REAL DEFAULT 0.0           -- 0.0 to 1.0
);

-- Pregnancy tracking (separate table, activated when pregnancy confirmed)
CREATE TABLE pregnancy (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  confirmed_date TEXT NOT NULL,
  due_date TEXT,
  current_week INTEGER,
  notes TEXT,
  active INTEGER DEFAULT 1,
  created_at TEXT NOT NULL
);

-- Streaks
CREATE TABLE streaks (
  id INTEGER PRIMARY KEY DEFAULT 1,
  current_streak INTEGER DEFAULT 0,
  best_streak INTEGER DEFAULT 0,
  last_active_week TEXT,              -- ISO date of last active week's Monday
  updated_at TEXT NOT NULL
);
```

### Firestore Schema

```
users/{uid}/
  ├── profile
  │   ├── language_code: string
  │   ├── created_at: timestamp
  │   ├── trial_expires_at: timestamp
  │   ├── subscription_status: 'trial' | 'active' | 'expired'
  │   ├── fcm_token: string
  │   └── timezone: string
  │
  ├── score
  │   ├── total: number
  │   ├── cycle_intelligence: number
  │   ├── mood_map: number
  │   ├── body_awareness: number
  │   ├── consistency: number
  │   └── updated_at: timestamp
  │
  ├── weekly_summaries/{week_id}
  │   ├── audio_url: string
  │   ├── insights: array<string>
  │   ├── score_change: number
  │   ├── generated_at: timestamp
  │   └── language_code: string
  │
  ├── milestones/{milestone_id}
  │   ├── unlocked: boolean
  │   ├── unlocked_at: timestamp
  │   └── progress: number
  │
  └── anonymized_data/
      ├── cycle_summaries: array<{start_date, length, flow}>
      ├── mood_weekly_avg: array<{week, avg_mood}>
      ├── symptom_frequencies: map<string, number>
      └── last_synced_at: timestamp
```

